:root{
  --bg:#0f172a;
  --sidebar:#020617;
  --panel:#111827;
  --card:#1e293b;
  --border:#334155;
  --text:#e5e7eb;
  --muted:#94a3b8;
  --primary:#2563eb;
  --danger:#dc2626;
  --success:#22c55e;
  --warning:#f59e0b;
}

*{
  box-sizing:border-box;
}

body{


  margin:0;
  background:var(--bg);
  color:var(--text);
  font-family:Inter,Segoe UI,sans-serif;
  display:flex;
}

.sidebar{
  width:240px;
  min-height:100vh;
  background:var(--sidebar);
  border-right:1px solid #0f172a;
  padding:28px;
}

.logo{
  font-size:28px;
  font-weight:800;
  margin-bottom:40px;
}

.sidebar nav a{
  display:block;
  padding:14px;
  border-radius:14px;
  margin-bottom:10px;
  color:var(--muted);
  text-decoration:none;
}

.sidebar nav a.active,
.sidebar nav a:hover{
  background:#1e293b;
  color:white;
}

.main{


  flex:1;
  padding:28px;
}

.topbar{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:30px;
}

.topbar p{
  color:var(--muted);
}

.top-actions{
  display:flex;
  gap:12px;
}

button{
  border:none;
  border-radius:14px;
  padding:12px 18px;
  color:white;
  background:#334155;
  cursor:pointer;
  font-weight:700;
}

button.primary{
  background:var(--primary);
}

button.danger{
  background:var(--danger);
}

.cards{
  display:grid;
  grid-template-columns:repeat(6,1fr);
  gap:16px;
  margin-bottom:22px;
}

.card{
  background:linear-gradient(180deg,#1e293b,#111827);
  border:1px solid var(--border);
  border-radius:22px;
  padding:22px;
  box-shadow:0 10px 30px rgba(0,0,0,.25);
}

.card span{
  color:var(--muted);
  font-size:13px;
}

.card strong{
  display:block;
  margin-top:12px;
  font-size:28px;
}

.grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:18px;
}

.panel{
  background:var(--panel);
  border:1px solid var(--border);
  border-radius:22px;
  padding:24px;
}

.panel.wide{
  grid-column:span 2;
}

.status-row{
  display:flex;
  justify-content:space-between;
  padding:12px 0;
  border-bottom:1px solid #1e293b;
  text-transform:capitalize;
}

.ok,
.online{
  color:var(--success);
}

.warning,
.medium{
  color:var(--warning);
}

.failed,
.offline,
.high{
  color:var(--danger);
}

.workflow-grid{
  display:grid;
  grid-template-columns:1fr 1fr 1fr;
  gap:16px;
  margin-bottom:18px;
}

label{
  display:block;
  margin-bottom:8px;
}

input,
select{
  width:100%;
  background:#0f172a;
  border:1px solid var(--border);
  border-radius:14px;
  padding:12px;
  color:white;
}

table{
  width:100%;
  border-collapse:collapse;
}

th,
td{
  text-align:left;
  padding:14px;
  border-bottom:1px solid #1e293b;
}

th{
  color:var(--muted);
  font-size:13px;
}

@media(max-width:1200px){

  .cards{
    grid-template-columns:repeat(2,1fr);
  }

  .grid{
    grid-template-columns:1fr;
  }

  .panel.wide{
    grid-column:span 1;
  }

  .workflow-grid{
    grid-template-columns:1fr;
  }

  body{


    display:block;
  }

  .sidebar{
    width:100%;
    min-height:auto;
  }

}
.indicator-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:12px;
  margin-bottom:20px;
}

.indicator{
  display:flex;
  align-items:center;
  gap:10px;
  background:#0f172a;
  border:1px solid var(--border);
  border-radius:14px;
  padding:12px;
  color:var(--text);
  font-weight:600;
}

.indicator span{
  width:10px;
  height:10px;
  border-radius:999px;
  display:inline-block;
}

.indicator.online span{
  background:var(--success);
  box-shadow:0 0 12px var(--success);
}

.indicator.warning span{
  background:var(--warning);
  box-shadow:0 0 12px var(--warning);
}

.indicator.failed span{
  background:var(--danger);
  box-shadow:0 0 12px var(--danger);
}

.activity-feed{
  display:flex;
  flex-direction:column;
  gap:10px;
  max-height:260px;
  overflow:auto;
}

.activity-item{
  background:#0f172a;
  border:1px solid var(--border);
  border-radius:14px;
  padding:12px 14px;
  color:var(--muted);
}

.run-report{
  background:#020617;
  border:1px solid var(--border);
  border-radius:16px;
  padding:18px;
  color:#dbeafe;
  overflow:auto;
  max-height:320px;
}
.activity-feed{
  display:flex;
  flex-direction:column;
  gap:10px;
  max-height:300px;
  overflow:auto;
}

.activity-item{
  background:#101a33;
  border:1px solid #24345d;
  padding:12px;
  border-radius:12px;
  color:#cfe2ff;
  font-size:14px;
}

.run-report{
  background:#09101f;
  border:1px solid #24345d;
  border-radius:12px;
  padding:20px;
  color:#8fd3ff;
  overflow:auto;
  max-height:400px;
}

.products-table{
  width:100%;
  border-collapse:collapse;
}

.products-table th,
.products-table td{
  border-bottom:1px solid #22345c;
  padding:14px;
  text-align:left;
}

.products-table tr:hover{
  background:#111c35;
}

.badge{
  padding:6px 10px;
  border-radius:999px;
  font-size:12px;
  font-weight:700;
}

.badge.success{
  background:#123f2d;
  color:#54ffae;
}

.badge.warning{
  background:#4d390c;
  color:#ffcb54;
}

.badge.danger{
  background:#4f1d1d;
  color:#ff8f8f;
}
/* LIVE PANELS */

.live-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;}

  display:grid;
  grid-template-columns:1fr 1fr;
  gap:24px;
  margin-top:24px;
}

.live-panel{
  background:#0f172a;
  border:1px solid #24345d;
  border-radius:24px;
  padding:24px;
}

.live-panel h2{
  margin-bottom:20px;
  font-size:28px;
}

.activity-feed{
  display:flex;
  flex-direction:column;
  gap:12px;
  max-height:320px;
  overflow-y:auto;
}

.activity-item{
  background:#111c35;
  border:1px solid #22345c;
  border-radius:14px;
  padding:14px;
  color:#d7e7ff;
  animation:fadeIn .3s ease;
}

.run-report{
  background:#09101f;
  border:1px solid #24345d;
  border-radius:14px;
  padding:18px;
  max-height:320px;
  overflow:auto;
  color:#8fd3ff;
  font-family:Consolas;
  white-space:pre-wrap;
}

.status-pulse{
  width:10px;
  height:10px;
  border-radius:999px;
  background:#22c55e;
  box-shadow:0 0 12px #22c55e;
  animation:pulse 1.5s infinite;
}

@keyframes pulse{
  0%{transform:scale(1);opacity:1;}
  50%{transform:scale(1.4);opacity:.5;}
  100%{transform:scale(1);opacity:1;}
}

@keyframes fadeIn{
  from{
    opacity:0;
    transform:translateY(10px);
  }
  to{
    opacity:1;
    transform:translateY(0);
  }
}


.chart-box{
  height:260px;
  background:#101a33;
  border:1px solid #24345d;
  border-radius:18px;
  padding:18px;
  margin-top:24px;
}

.chart-bars{
  display:flex;
  align-items:flex-end;
  gap:16px;
  height:180px;
  margin-top:30px;
}

.chart-bar{
  flex:1;
  background:linear-gradient(180deg,#2563eb,#60a5fa);
  border-radius:12px 12px 0 0;
  transition:.3s;
}

.chart-bar:hover{
  transform:translateY(-6px);
}

.chart-labels{
  display:flex;
  gap:16px;
  margin-top:10px;
}

.chart-labels div{
  flex:1;
  text-align:center;
  color:#9fb3d9;
}

.chart-box{
  height:260px;
  background:#101a33;
  border:1px solid #24345d;
  border-radius:18px;
  padding:18px;
  margin-top:24px;
}

.chart-bars{
  display:flex;
  align-items:flex-end;
  gap:16px;
  height:180px;
  margin-top:30px;
}

.chart-bar{
  flex:1;
  background:linear-gradient(180deg,#2563eb,#60a5fa);
  border-radius:12px 12px 0 0;
  transition:.3s;
}

.chart-bar:hover{
  transform:translateY(-6px);
}

.chart-labels{
  display:flex;
  gap:16px;
  margin-top:10px;
}

.chart-labels div{
  flex:1;
  text-align:center;
  color:#9fb3d9;
}


.progress-shell{
  width:100%;
  height:14px;
  background:#0b1224;
  border:1px solid #24345d;
  border-radius:999px;
  overflow:hidden;
  margin-top:16px;
}

.progress-bar{
  width:0%;
  height:100%;
  background:linear-gradient(90deg,#2563eb,#22c55e);
  transition:width .5s ease;
}

.monitor-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:16px;
}

.monitor-card{
  background:#101a33;
  border:1px solid #24345d;
  border-radius:18px;
  padding:18px;
}

.monitor-card span{
  color:#9fb3d9;
  font-size:13px;
}

.monitor-card strong{
  display:block;
  margin-top:8px;
  font-size:22px;
}

.history-list{
  display:flex;
  flex-direction:column;
  gap:12px;
}

.history-item{
  background:#101a33;
  border:1px solid #24345d;
  border-radius:14px;
  padding:14px;
  display:flex;
  justify-content:space-between;
  gap:16px;
}

@media(max-width:1200px){
  .monitor-grid{
    grid-template-columns:1fr 1fr;
  }
}

.score-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:16px;
}

.score-card{
  background:#101a33;
  border:1px solid #24345d;
  border-radius:18px;
  padding:18px;
}

.score-card span{
  color:#9fb3d9;
  font-size:13px;
}

.score-card strong{
  display:block;
  margin-top:8px;
  font-size:26px;
}


.connection-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:16px;
}

.connection-card{
  background:#101a33;
  border:1px solid #24345d;
  border-radius:18px;
  padding:18px;
}

.connection-card span{
  color:#9fb3d9;
  font-size:13px;
}

.connection-card strong{
  display:block;
  margin-top:8px;
  font-size:22px;
}

.emergency-box{
  margin-top:20px;
  background:#2a1111;
  border:1px solid #7f1d1d;
  border-radius:18px;
  padding:18px;
}

.emergency-box p{
  color:#fecaca;
}


.toast-stack{
  position:fixed;
  right:24px;
  bottom:24px;
  display:flex;
  flex-direction:column;
  gap:12px;
  z-index:9999;
}

.toast{
  min-width:280px;
  background:#101a33;
  border:1px solid #24345d;
  color:#dbeafe;
  border-radius:16px;
  padding:14px 16px;
  box-shadow:0 20px 40px rgba(0,0,0,.35);
  animation:fadeIn .25s ease;
}

.toast.success{
  border-color:#14532d;
}

.toast.warning{
  border-color:#92400e;
}

.toast.danger{
  border-color:#7f1d1d;
}

button.loading{
  opacity:.7;
  pointer-events:none;
}

button.loading::after{
  content:" ...";
}


.queue-toolbar{
  display:flex;
  gap:12px;
  margin-bottom:18px;
}

.queue-toolbar input,
.queue-toolbar select{
  max-width:260px;
}

.hidden-row{
  display:none;
}


.utility-actions{
  display:flex;
  gap:12px;
  flex-wrap:wrap;
  margin-top:18px;
}


.settings-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:16px;
}

body.light-mode{
  --bg:#f1f5f9;
  --sidebar:#ffffff;
  --panel:#ffffff;
  --card:#e2e8f0;
  --border:#cbd5e1;
  --text:#0f172a;
  --muted:#475569;
}

@media(max-width:1200px){
  .settings-grid{
    grid-template-columns:1fr 1fr;
  }
}


.debug-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:16px;
}

.debug-card{
  background:#101a33;
  border:1px solid #24345d;
  border-radius:18px;
  padding:18px;
}

.debug-card span{
  color:#9fb3d9;
  font-size:13px;
}

.debug-card strong{
  display:block;
  margin-top:8px;
  font-size:18px;
}

.debug-error{
  margin-top:18px;
  background:#2a1111;
  border:1px solid #7f1d1d;
  border-radius:14px;
  padding:14px;
  color:#fecaca;
  white-space:pre-wrap;
}

@media(max-width:1200px){
  .debug-grid{
    grid-template-columns:1fr 1fr;
  }
}


.log-viewer{
  background:#020617;
  border:1px solid #24345d;
  border-radius:18px;
  padding:18px;
  max-height:360px;
  overflow:auto;
  color:#c7d2fe;
  font-family:Consolas,monospace;
  white-space:pre-wrap;
}

.log-toolbar{
  display:flex;
  gap:12px;
  margin-bottom:16px;
  flex-wrap:wrap;
}


.reports-list{
  display:flex;
  flex-direction:column;
  gap:12px;
}

.report-item{
  background:#101a33;
  border:1px solid #24345d;
  border-radius:14px;
  padding:14px;
  display:flex;
  justify-content:space-between;
  gap:18px;
}

.report-item span{
  color:#9fb3d9;
  font-size:13px;
}


.report-preview{
  background:#020617;
  border:1px solid #24345d;
  border-radius:18px;
  padding:18px;
  margin-top:18px;
  max-height:420px;
  overflow:auto;
  color:#dbeafe;
  font-family:Consolas,monospace;
  white-space:pre-wrap;
}

.report-item{
  cursor:pointer;
}

.report-item:hover{
  background:#172340;
}


.readiness-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:16px;
}

.readiness-card{
  background:#101a33;
  border:1px solid #24345d;
  border-radius:18px;
  padding:18px;
}

.readiness-card span{
  color:#9fb3d9;
  font-size:13px;
}

.readiness-card strong{
  display:block;
  margin-top:8px;
  font-size:18px;
}


.env-table{
  width:100%;
  border-collapse:collapse;
  margin-top:18px;
}

.env-table th,
.env-table td{
  border-bottom:1px solid #24345d;
  padding:12px;
  text-align:left;
}

.env-table .missing{
  color:#f87171;
  font-weight:700;
}

.env-table .set{
  color:#22c55e;
  font-weight:700;
}


.quick-actions{
  display:flex;
  gap:10px;
  flex-wrap:wrap;
  margin:0 0 24px 0;
}

.quick-actions button{
  background:#101a33;
  border:1px solid #24345d;
}


.panel h2{
  display:flex;
  align-items:center;
  justify-content:space-between;
  cursor:pointer;
}

.panel h2::after{
  content:"−";
  font-size:22px;
  color:#9fb3d9;
}

.panel.collapsed h2::after{
  content:"+";
}

.panel.collapsed > *:not(h2){
  display:none !important;
}


.version-badge{
  display:inline-flex;
  align-items:center;
  gap:8px;
  background:#101a33;
  border:1px solid #24345d;
  border-radius:999px;
  padding:8px 14px;
  color:#93c5fd;
  font-size:13px;
  font-weight:700;
  margin-top:10px;
}

.changelog-list{
  display:flex;
  flex-direction:column;
  gap:10px;
}

.changelog-item{
  background:#101a33;
  border:1px solid #24345d;
  border-radius:14px;
  padding:14px;
  color:#dbeafe;
}


.audit-list{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:12px;
}

.audit-item{
  background:#101a33;
  border:1px solid #24345d;
  border-radius:14px;
  padding:14px;
}

.audit-ok{
  color:#22c55e;
}

.audit-missing{
  color:#f87171;
}

@media(max-width:1200px){
  .audit-list{
    grid-template-columns:1fr;
  }
}


body.glass-mode{
  background:
    radial-gradient(circle at top left,#1e293b,#020617 60%),
    linear-gradient(135deg,#0f172a,#111827);
}

body.glass-mode .card,
body.glass-mode .panel,
body.glass-mode .report-item,
body.glass-mode .audit-item,
body.glass-mode .readiness-card,
body.glass-mode .activity-item{
  background:rgba(15,23,42,0.72);
  backdrop-filter:blur(12px);
  border:1px solid rgba(255,255,255,0.08);
  box-shadow:0 10px 30px rgba(0,0,0,0.35);
}

.theme-toggle{
  margin-left:auto;
}


body.compact-mode .main{
  padding:18px;
}

body.compact-mode .panel,
body.compact-mode .card{
  padding:14px;
  border-radius:16px;
}

body.compact-mode h1{
  font-size:26px;
}

body.compact-mode h2{
  font-size:20px;
}

body.compact-mode .cards,
body.compact-mode .grid{
  gap:12px;
}

body.compact-mode button{
  padding:9px 12px;
}

body.compact-mode .card strong{
  font-size:22px;
}


.command-center{
  position:fixed;
  inset:0;
  background:rgba(2,6,23,.75);
  backdrop-filter:blur(8px);
  display:none;
  align-items:flex-start;
  justify-content:center;
  padding-top:90px;
  z-index:10000;
}

.command-center.open{
  display:flex;
}

.command-box{
  width:min(720px,92vw);
  background:#0f172a;
  border:1px solid #24345d;
  border-radius:24px;
  padding:20px;
  box-shadow:0 30px 80px rgba(0,0,0,.45);
}

.command-box input{
  font-size:18px;
  margin-bottom:16px;
}

.command-item{
  padding:14px;
  border-radius:14px;
  cursor:pointer;
  color:#dbeafe;
}

.command-item:hover{
  background:#1e293b;
}


.shortcuts-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:12px;
}

.shortcut-card{
  background:#101a33;
  border:1px solid #24345d;
  border-radius:14px;
  padding:14px;
}

.shortcut-key{
  display:inline-block;
  background:#020617;
  border:1px solid #334155;
  border-radius:8px;
  padding:4px 8px;
  color:#93c5fd;
  font-family:Consolas,monospace;
  margin-bottom:8px;
}

@media(max-width:1200px){
  .shortcuts-grid{
    grid-template-columns:1fr;
  }
}


.topbar-meta{
  display:flex;
  align-items:center;
  gap:16px;
  margin-top:10px;
  flex-wrap:wrap;
}

.meta-pill{
  background:#101a33;
  border:1px solid #24345d;
  border-radius:999px;
  padding:8px 14px;
  color:#cbd5e1;
  font-size:13px;
  font-weight:600;
}


.status-footer{
  position:sticky;
  bottom:0;
  margin-top:28px;
  background:rgba(2,6,23,.92);
  backdrop-filter:blur(10px);
  border:1px solid #24345d;
  border-radius:18px 18px 0 0;
  padding:12px 18px;
  display:flex;
  gap:18px;
  flex-wrap:wrap;
  z-index:100;
}

.status-footer span{
  color:#9fb3d9;
  font-size:13px;
}

.status-footer strong{
  color:#dbeafe;
}

