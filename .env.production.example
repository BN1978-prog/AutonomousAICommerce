# ===============================
# ENVIRONMENT
# ===============================
APP_ENV=production
APP_NAME=AutonomousAICommerce
LOG_LEVEL=INFO

# ===============================
# SAFETY
# ===============================
DRY_RUN=true
AUTONOMY_ENABLED=false
EMERGENCY_STOP=false

MAX_DAILY_SPEND=250
MAX_SINGLE_ORDER_SPEND=50
MIN_MARGIN_PERCENT=25
MAX_RISK_SCORE=45
MAX_PRODUCTS_PER_CYCLE=3
AUTONOMOUS_INTERVAL_SECONDS=60

# ===============================
# DATABASE
# ===============================
# SQLite fallback:
# DATABASE_URL=sqlite:///./commerce.db

# PostgreSQL production:
DATABASE_URL=postgresql://commerce_user:commerce_password@localhost:5432/commerce_db

# ===============================
# SHOPIFY
# ===============================
SHOPIFY_STORE_URL=
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2025-01

# ===============================
# SUPPLIERS
# ===============================
SUPPLIER_MODE=sandbox
CJDROPSHIPPING_API_KEY=
BIGBUY_API_KEY=
SYNCEE_API_KEY=

# ===============================
# SHIPPING
# ===============================
SHIPPING_MODE=sandbox
ROYAL_MAIL_API_KEY=
DHL_API_KEY=
DPD_API_KEY=
EVRI_API_KEY=

# ===============================
# AI
# ===============================
OPENAI_API_KEY=
AI_MODEL=gpt-4.1-mini
